   "source": [
    "import time\n",
    "\n",
    "\n",
    "def timer(func):\n",
    "\tdef wrapper(*args, **kwargs):\n",
    "\t\tstart = time.time()\n",
    "\t\tf = func(*args, **kwargs)\n",
    "\t\tfinish = time.time()\n",
    "\n",
    "\t\tprint(f\"Время работа алгоритма: {finish - start}\")\n",
    "\t\treturn f\n",
    "\treturn wrapper\n",
    "\n",
    "\n",
    "@timer\n",
    "def foo(a, b):\n",
    "\treturn a if a > b else b\n",
    "\n",
    "\n",
    "foo(2, 3)"
   ]
  }
 ],
